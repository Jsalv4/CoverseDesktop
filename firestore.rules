rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function sessionPath(sessionId) {
      return /databases/$(database)/documents/sessions/$(sessionId);
    }

    function voiceParticipantPath(sessionId, channelId, uid) {
      return /databases/$(database)/documents/sessions/$(sessionId)/voiceChannels/$(channelId)/participants/$(uid);
    }

    function controlRequestPath(sessionId, channelId, requestId) {
      return /databases/$(database)/documents/sessions/$(sessionId)/voiceChannels/$(channelId)/remoteControlRequests/$(requestId);
    }

    function isSessionMember(sessionId) {
      return isSignedIn() &&
        exists(sessionPath(sessionId)) &&
        request.auth.uid in get(sessionPath(sessionId)).data.memberIds;
    }

    function isVoiceParticipantActive(sessionId, channelId, uid) {
      return isSessionMember(sessionId) &&
        exists(voiceParticipantPath(sessionId, channelId, uid)) &&
        get(voiceParticipantPath(sessionId, channelId, uid)).data.isInVoice == true;
    }

    function isVoiceParticipantSharing(sessionId, channelId, uid) {
      return isVoiceParticipantActive(sessionId, channelId, uid) &&
        get(voiceParticipantPath(sessionId, channelId, uid)).data.isScreenSharing == true;
    }

    function canJoinSessionViaInvite(sessionId) {
      return isSignedIn() &&
        !isSessionMember(sessionId) &&
        resource.data.memberIds is list &&
        request.resource.data.memberIds is list &&
        resource.data.inviteCode is string &&
        request.resource.data.inviteCode == resource.data.inviteCode &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
        request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt', 'inviteCode']);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSelf(uid);

      match /library/{fileId} {
        allow read, write: if isSelf(uid);
      }
    }

    match /userLibraries/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /library/{fileId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.resource.data.ownerUid == request.auth.uid ||
        request.resource.data.uid == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds ||
        canJoinSessionViaInvite(sessionId)
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerUid;

      match /channels/{channelId}/messages/{messageId} {
        allow read: if isSessionMember(sessionId);
        allow create: if isSessionMember(sessionId) &&
          request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isSessionMember(sessionId) &&
          resource.data.senderUid == request.auth.uid;
      }

      match /voiceChannels/{channelId} {
        allow read: if isSessionMember(sessionId);
        allow create, update: if isSessionMember(sessionId);
        allow delete: if false;

        match /participants/{uid} {
          allow read: if isSessionMember(sessionId);
          allow create, update: if isSessionMember(sessionId) &&
            request.auth.uid == uid &&
            request.resource.data.uid == uid &&
            request.resource.data.sessionId == sessionId &&
            request.resource.data.channelId == channelId;
          allow delete: if false;
        }

        match /remoteControlRequests/{requestId} {
          allow read: if isSessionMember(sessionId);

          allow create: if isSessionMember(sessionId) &&
            request.auth.uid == request.resource.data.requesterUid &&
            request.resource.data.requesterUid is string &&
            request.resource.data.targetUid is string &&
            request.resource.data.targetUid != request.auth.uid &&
            request.resource.data.sessionId == sessionId &&
            request.resource.data.channelId == channelId &&
            request.resource.data.status == 'pending' &&
            request.resource.data.expiresAt is timestamp &&
            request.resource.data.expiresAt > request.time &&
            isVoiceParticipantActive(sessionId, channelId, request.auth.uid) &&
            isVoiceParticipantSharing(sessionId, channelId, request.resource.data.targetUid);

          allow update: if isSessionMember(sessionId) &&
            request.resource.data.requesterUid == resource.data.requesterUid &&
            request.resource.data.targetUid == resource.data.targetUid &&
            request.resource.data.sessionId == resource.data.sessionId &&
            request.resource.data.channelId == resource.data.channelId &&
            (
              (
                request.auth.uid == resource.data.targetUid &&
                resource.data.status == 'pending' &&
                request.resource.data.status in ['approved', 'denied', 'expired']
              ) ||
              (
                request.auth.uid == resource.data.targetUid &&
                resource.data.status == 'approved' &&
                request.resource.data.status in ['revoked', 'expired']
              ) ||
              (
                request.auth.uid == resource.data.requesterUid &&
                resource.data.status == 'pending' &&
                request.resource.data.status == 'revoked'
              )
            );

          allow delete: if false;
        }

        match /remoteControlGrants/{targetUid} {
          allow read: if isSessionMember(sessionId);

          allow create: if isSessionMember(sessionId) &&
            request.auth.uid == targetUid &&
            request.resource.data.targetUid == targetUid &&
            request.resource.data.controllerUid is string &&
            request.resource.data.controllerUid != targetUid &&
            request.resource.data.sessionId == sessionId &&
            request.resource.data.channelId == channelId &&
            request.resource.data.isActive == true &&
            request.resource.data.requestId is string &&
            isVoiceParticipantSharing(sessionId, channelId, targetUid) &&
            isVoiceParticipantActive(sessionId, channelId, request.resource.data.controllerUid) &&
            exists(controlRequestPath(sessionId, channelId, request.resource.data.requestId)) &&
            get(controlRequestPath(sessionId, channelId, request.resource.data.requestId)).data.status == 'approved' &&
            get(controlRequestPath(sessionId, channelId, request.resource.data.requestId)).data.targetUid == targetUid &&
            get(controlRequestPath(sessionId, channelId, request.resource.data.requestId)).data.requesterUid == request.resource.data.controllerUid;

          allow update: if isSessionMember(sessionId) &&
            request.resource.data.targetUid == resource.data.targetUid &&
            request.resource.data.controllerUid == resource.data.controllerUid &&
            request.resource.data.sessionId == resource.data.sessionId &&
            request.resource.data.channelId == resource.data.channelId &&
            (
              request.auth.uid == targetUid ||
              request.auth.uid == resource.data.controllerUid
            );

          allow delete: if false;
        }

        match /signals/{signalId} {
          allow read: if isSessionMember(sessionId);
          allow create: if isSessionMember(sessionId) &&
            request.resource.data.from == request.auth.uid &&
            request.resource.data.to is string &&
            request.resource.data.type is string;
          allow delete: if isSessionMember(sessionId) &&
            (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
          allow update: if false;
        }
      }
    }

    match /sessionInviteCodes/{inviteCode} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create, update: if isSignedIn() &&
        request.resource.data.inviteCode == inviteCode &&
        request.resource.data.sessionId is string &&
        exists(sessionPath(request.resource.data.sessionId)) &&
        isSessionMember(request.resource.data.sessionId) &&
        request.resource.data.ownerUid == get(sessionPath(request.resource.data.sessionId)).data.ownerUid;

      allow delete: if false;
    }

    match /sessionInvites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow delete: if isSignedIn() && resource.data.fromUid == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.resource.data.follower == request.auth.uid;
      allow update: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn() &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() >= 2 &&
        request.auth.uid in request.resource.data.participants;

      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    match /messages/{messageId} {
      allow read, write: if isSignedIn();
    }
  }
}
